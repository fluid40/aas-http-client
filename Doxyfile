# -------------------------------------------------------------
#              OPTIMIZED DOXYFILE FOR PYTHON + DOXYPYPY
# -------------------------------------------------------------

DOXYFILE_ENCODING       = UTF-8
PROJECT_NAME            = "HTTP Client Documentation"
OUTPUT_DIRECTORY        = ./doc

# -------------------------------------------------------------
# Input
# -------------------------------------------------------------
INPUT                   = aas_http_client \
                          tests \
                          README.md

RECURSIVE               = YES

# Dateien erkennen (WICHTIG: keine kaputten *.py= Einträge!)
FILE_PATTERNS           = *.py *.md

# Python-Filter aktivieren
FILTER_PATTERNS         = *.py=python3 -m doxypypy
PYTHON_DOCSTRING        = NO

# -------------------------------------------------------------
# Extraction settings
# -------------------------------------------------------------
EXTRACT_ALL             = YES
EXTRACT_PRIVATE         = NO
EXTRACT_STATIC          = NO
EXTRACT_LOCAL_CLASSES   = YES
OPTIMIZE_OUTPUT_JAVA    = NO

# -------------------------------------------------------------
# Markup / Formatting
# ------------------------------------------------------------
MARKDOWN_SUPPORT        = YES
USE_MDFILE_AS_MAINPAGE  = README.md

# -------------------------------------------------------------
# HTML Output
# -------------------------------------------------------------
GENERATE_HTML           = YES
HTML_OUTPUT             = html
GENERATE_TREEVIEW       = YES

# -------------------------------------------------------------
# Graphviz / DOT (fully Linux-compatible)
# -------------------------------------------------------------
HAVE_DOT                = YES
DOT_IMAGE_FORMAT        = svg
INTERACTIVE_SVG         = YES

# Entferne WINDOWS-/Conda-Pfade!
DOT_PATH                =
DOT_FONTPATH            =

CLASS_GRAPH             = YES
COLLABORATION_GRAPH     = YES
INCLUDE_GRAPH           = YES
INCLUDED_BY_GRAPH       = YES
CALL_GRAPH              = YES
CALLER_GRAPH            = YES

# -------------------------------------------------------------
# Source browsing
# -------------------------------------------------------------
SOURCE_BROWSER          = YES
INLINE_SOURCES          = NO

# -------------------------------------------------------------
# Misc
# -------------------------------------------------------------
QUIET                   = NO
WARNINGS                = YES
